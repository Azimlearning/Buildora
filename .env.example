# Buildora Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# AI / LLM Configuration
# ============================================
GLM_API_KEY=your_glm_api_key_here
GLM_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
GLM_MODEL=glm-4-flash

# ============================================
# Database Configuration
# ============================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=buildora
POSTGRES_USER=buildora_user
POSTGRES_PASSWORD=change_this_password

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password
REDIS_DB=0

# ============================================
# MinIO Object Storage
# ============================================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_this_minio_password
MINIO_BUCKET=buildora-documents
MINIO_SECURE=false

# ============================================
# Telegram Bot (Agent B Notifications)
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ============================================
# FastAPI Configuration
# ============================================
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_RELOAD=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# Frontend Configuration
# ============================================
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=Buildora

# ============================================
# Application Settings
# ============================================
DEBUG=true
LOG_LEVEL=INFO
ENVIRONMENT=development

# ============================================
# Agent Configuration
# ============================================
# Agent B thresholds
DELAY_THRESHOLD_DAYS=3
COST_VARIANCE_THRESHOLD=0.08

# Agent C compliance
CIDB_PASS_SCORE=70
